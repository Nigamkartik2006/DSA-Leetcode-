Given an array nums of integers, return how many of them contain an even number of digits.


Solution

 class Solution {
    public int findNumbers(int[] nums) {

        int n = nums.length;

        int countn = 0;

        for(int i = 0; i < n; i++) {

            int count = 0;

            int nu = nums[i];

            while(nu > 0) {

                nu = nu / 10;

                count++;
            }

            if(count % 2 == 0) {
                countn++;
            }
        }

        return countn;
    }
}
