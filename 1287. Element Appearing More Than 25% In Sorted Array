Given an integer array sorted in non-decreasing order, there is exactly one integer in the array that occurs more than 25% of the time, return that integer.

Solution

 class Solution {
    public int findSpecialInteger(int[] arr) {
        int n = arr.length;

        for (int i = 0; i < n; i++) {
            int count = 1;

            for (int j = i + 1; j < n; j++) {
                if (arr[i] == arr[j]) {
                    count++;
                }
            }

            if (count > n / 4) {
                return arr[i];
            }
        }

        return -1;
    }
}
