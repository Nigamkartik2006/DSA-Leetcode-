class Solution {
    public List<Integer> findDisappearedNumbers(int[] nums) {
        int n = nums.length;

        Set<Integer> new_set = new HashSet<>();
        for (int num : nums) {
            new_set.add(num);
        }

        List<Integer> result = new ArrayList<>();

        for (int i = 1; i <= n; i++) {   
            if (!new_set.contains(i)) {
                result.add(i);
            }
        }

        return result;    
    }
}
