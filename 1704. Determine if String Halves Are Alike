1704. Determine if String Halves Are Alike



class Solution(object):
    def halvesAreAlike(self, s):
        mid=len(s)//2
        a=s[:mid]
        b=s[mid:]
        counta=0
        countb=0

        for ch in a:
            if ch.lower()in "aeiou":
                counta+=1
        for ch in b:
            if ch.lower()in "aeiou":
                countb+=1
        if counta==countb:
            return True
        else:
            return False
