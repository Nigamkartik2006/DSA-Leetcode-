Given the head of a linked list, remove the nth node from the end of the list and return its head.

SOlution

class Solution {
    public ListNode removeNthFromEnd(ListNode head, int n) {

        if (head == null) {
            return null;
        }
 
        int count = 0;
        ListNode temp = head;

        while (temp != null) {
            count++;
            temp = temp.next;
        }

        
        if (count == n) {
            return head.next;
        }
 
        temp = head;
        for (int i = 1; i < count - n; i++) {
            temp = temp.next;
        }

        temp.next = temp.next.next;

        return head;
    }
}
