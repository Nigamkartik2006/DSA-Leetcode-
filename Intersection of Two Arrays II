Given two integer arrays nums1 and nums2, return an array of their intersection. Each element in the result must appear as many times as it shows in both arrays and you may return the result in any order.Given two integer arrays nums1 and nums2, return an array of their intersection. Each element in the result must appear as many times as it shows in both arrays and you may return the result in any order.
Solution

class Solution {
    public int[] intersect(int[] nums1, int[] nums2) {
        ArrayList<Integer> list= new ArrayList<>();
     int n= nums1.length;
     int m=nums2.length;
     for(int i=0;i<n;i++){
        for(int j=0;j<m;j++){
            if(nums1[i]==nums2[j]){
                list.add(nums1[i]);
                 nums2[j] = -1;
                 break;
            }
        }
     }
     int[] arr = new int[list.size()];

for(int i = 0; i < list.size(); i++) {
    arr[i] = list.get(i);
}
return arr;

    }
}
